# ── Bandcamp HTTP ─────────────────────────────────────────────────────────────

# Delay between Bandcamp HTTP requests in milliseconds.
# Single value (e.g. 1500) or range (e.g. 1000-3000).
BC_REQUEST_DELAY=1000-3000

# Number of times to retry a failed HTTP request before giving up.
BC_MAX_RETRIES=12

# Initial retry delay in seconds; multiplied by attempt number (exponential back-off).
# e.g. attempt 1 waits 5s, attempt 2 waits 10s, attempt 3 waits 15s.
BC_RETRY_DELAY=5

# HTTP request timeout in seconds.
BC_REQUEST_TIMEOUT=30

# ── Browsertrix / Podman ──────────────────────────────────────────────────────

BROWSERTRIX_IMAGE=ghcr.io/webrecorder/browsertrix-crawler:latest

# Container runtime to use. Change to "docker" if Podman is not available.
CONTAINER_RUNTIME=podman

# Directory where finished .wacz files are written.
# Relative to the project root, or absolute.
WACZ_OUTPUT_DIR=wacz_output

# How long Browsertrix waits for the page DOM to settle before running behaviors.
# Valid values: load, domcontentloaded, networkidle0, networkidle2
CRAWL_WAIT_UNTIL=networkidle2

# Seconds Browsertrix will wait for a page to load before giving up.
CRAWL_PAGE_LOAD_TIMEOUT=90

# Seconds Browsertrix allows for page behaviors (e.g. the audio-fetch script).
# Must be long enough for the largest album you expect to archive.
CRAWL_BEHAVIOR_TIMEOUT=1800

# Number of times to retry a failed crawl before giving up.
CRAWL_MAX_RETRIES=3

# Seconds to wait before retrying a failed crawl (linear back-off: delay × attempt).
# e.g. attempt 1 waits 30s, attempt 2 waits 60s, attempt 3 waits 90s.
CRAWL_RETRY_DELAY=30

# Starting inter-track delay in milliseconds passed to the behavior script.
# Doubled after each rate-limit retry; resets to this value after every successful crawl.
CRAWL_TRACK_DELAY_MS=100

# Number of times to retry when Bandcamp rate-limits the crawl (HTTP 429).
# Counted separately from CRAWL_MAX_RETRIES. Set to 0 to disable rate-limit retries.
CRAWL_RATE_LIMIT_MAX_RETRIES=3

# Seconds to wait before retrying after a rate limit (linear back-off: delay × attempt).
# Longer than CRAWL_RETRY_DELAY because rate limits need time to clear.
# e.g. attempt 1 waits 120s, attempt 2 waits 240s, attempt 3 waits 360s.
CRAWL_RATE_LIMIT_RETRY_DELAY=120

# ── Filename limits ───────────────────────────────────────────────────────────

# Maximum filename size in bytes (pixeldrain enforces a 255-character limit).
FILENAME_MAX_BYTES=210

# How to truncate filenames that exceed FILENAME_MAX_BYTES.
# Options:
#   end    — cut the title at the byte limit
#   middle — remove characters from the middle, keeping start and end visible
#   hash   — replace the title with a short SHA-1 hash (unambiguous, not readable)
FILENAME_TRUNCATION=middle

# ── Pixeldrain ────────────────────────────────────────────────────────────────

# API key from pixeldrain.com/user/api_keys
PD_API_KEY=your_pixeldrain_api_key_here

# Number of times to retry a failed upload before giving up.
PD_MAX_RETRIES=5

# Seconds to wait before retrying a failed upload (linear back-off: delay × attempt).
# e.g. attempt 1 waits 10s, attempt 2 waits 20s, ..., attempt 5 waits 50s.
PD_RETRY_DELAY=10

# ── Email watcher (Step 6) ────────────────────────────────────────────────────

EMAIL_ADDRESS=your_email@example.com
EMAIL_PASSWORD=your_app_password_here
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993


